# ─── apps/api ───────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/campaign_manager
DATABASE_URL=postgresql://localhost:5432/campaign_manager

# JWT signing secret (generate a random string, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token expiry duration
JWT_EXPIRES_IN=7d

# API HTTP port (defaults to 3000)
PORT=3000

# ─── apps/web ───────────────────────────────────────────────────────────────────

# Base URL for API calls from the browser
VITE_API_URL=http://localhost:3000
